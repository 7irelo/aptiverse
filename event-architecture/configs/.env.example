# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_ACKS=all
KAFKA_RETRIES=3
KAFKA_CLIENT_ID=aptiverse-event-server

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_RETRIES=3

# Deduplication
DEDUP_WINDOW_SIZE=100000
DEDUP_TTL=10m

# Rate Limiting
RATE_LIMIT_PER_SOURCE=1000

# Batch
MAX_BATCH_SIZE=100

# Environment: development | production
ENVIRONMENT=development
